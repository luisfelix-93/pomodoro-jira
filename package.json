{
  "name": "pomerode-jira",
  "version": "0.0.3",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:electron\"",
    "dev:client": "vite",
    "dev:server": "cd server && npm run dev",
    "dev:electron": "wait-on tcp:5173 tcp:3001 && tsc -p electron && cross-env NODE_ENV=development electron .",
    "build": "tsc -b && vite build && tsc -p electron && npm run build:server",
    "build:server": "cd server && npm run build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "keywords": [
    "pomodoro",
    "jira",
    "electron",
    "react",
    "productivity"
  ],
  "author": "Luís F. (Pomodoro Jira)",
  "license": "MIT",
  "description": "A desktop productivity tool integrating Pomodoro technique with Jira time tracking.",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@lucide/lab": "^0.1.2",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.574.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^7.3.1",
    "zustand": "^5.0.11"
  }
}
